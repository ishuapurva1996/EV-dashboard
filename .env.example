# Copy this file to .env and fill in the personal fields below.
# The shared values (account, database, schema, role) are the same for all teammates.

# ─── Shared (everyone uses these exact values) ─────────────
SNOWFLAKE_ACCOUNT=SFEDU02-EAB27764
SNOWFLAKE_DATABASE=USER_DB_BADGER
SNOWFLAKE_SCHEMA=ANALYTICS_EV
SNOWFLAKE_ROLE=TRAINING_ROLE

# ─── Personal (your own training account) ──────────────────
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=

# ─── Other ─────────────────────────────────────────────────
# DBT_PROFILES_DIR points at the project-local profiles.yml inside the Airflow container.
# Leave as-is unless you change the compose mount.
DBT_PROFILES_DIR=/opt/airflow/dbt

# API keys for ingestion DAGs (each teammate registers their own — both are free + instant)
NREL_API_KEY=
CENSUS_API_KEY=

# Airflow user id inside the container (50000 is the default — leave as-is)
AIRFLOW_UID=50000
