# Copy this file to .env and fill in your own values.
# Each teammate has their own Snowflake training user — do NOT share.

SNOWFLAKE_ACCOUNT=SFEDU02-EAB27764
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRAINING_ROLE
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_SCHEMA=analytics

# DBT_PROFILES_DIR points at the project-local profiles.yml inside the Airflow container.
# Leave as-is unless you change the compose mount.
DBT_PROFILES_DIR=/opt/airflow/dbt

# API keys for ingestion DAGs
NREL_API_KEY=
CENSUS_API_KEY=

# Airflow user id inside the container (50000 is the default)
AIRFLOW_UID=50000
